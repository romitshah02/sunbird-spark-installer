              "analyzer": "keylower",
              "fielddata": true
            }
          },
          "copy_to": [
            "all_fields"
          ],
          "analyzer": "cs_index_analyzer",
          "search_analyzer": "cs_search_analyzer",
          "fielddata": true
        },
        "data": {
          "type": "object"
        },
        "createdBy": {
