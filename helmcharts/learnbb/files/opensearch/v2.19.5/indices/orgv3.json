{
    "settings": {
        "index": {
            "number_of_shards": "5",
            "number_of_replicas": "1",
            "analysis": {
                "filter": {
                    "mynGram": {
                        "type": "ngram",
                        "min_gram": "3",
                        "max_gram": "4",
                        "token_chars": [
                            "letter",
                            "digit",
                            "whitespace",
                            "punctuation",
                            "symbol"
                        ]
                    }
                },
                "analyzer": {
                    "cs_index_analyzer": {
                        "type": "custom",
                        "tokenizer": "standard",
                        "filter": [
                            "lowercase",
                            "mynGram"
                        ]
                    },
                    "keylower": {
                        "type": "custom",
                        "tokenizer": "keyword",
                        "filter": [
                            "lowercase"
                        ]
                    },
                    "cs_search_analyzer": {
                        "type": "custom",
                        "tokenizer": "standard",
                        "filter": [
                            "lowercase"
                        ]
                    }
                }
            }
        }
    },
    "aliases": {
        "org_alias": {}
    }
}