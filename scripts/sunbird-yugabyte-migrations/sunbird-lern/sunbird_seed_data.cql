-- Table: notification_template
INSERT INTO sunbird_notifications.notification_template(templateId, type, ver, data, template_schema) VALUES ('user-added-to','JSON','4.3.0','{"title": "you have been added to ${param1} by ${param2}"}', '{"$schema":"#/definition/params","title":"params context","description":"properties Data","type":"object","properties":{"param1":{"description":"property 1 value","type":"string"},"param2":{"description":"property 2 value","type":"string"}},"required":["param1","param2"]}') IF NOT EXISTS;
INSERT INTO sunbird_notifications.notification_template(templateId, type, ver, data, template_schema) VALUES ('user-exit','JSON','4.3.0','{"title": "${param1} has left the ${param2}"}', '{"$schema":"#/definition/params","title":"params context","description":"properties Data","type":"object","properties":{"param1":{"description":"property 1 value","type":"string"},"param2":{"description":"property 2 value","type":"string"}},"required":["param1","param2"]}') IF NOT EXISTS;
INSERT INTO sunbird_notifications.notification_template(templateId, type, ver, data, template_schema) VALUES ('user-removed','JSON','4.3.0','{"title": "you have been removed from the ${param1} by ${param2}"}', '{"$schema":"#/definition/params","title":"params context","description":"properties Data","type":"object","properties":{"param1":{"description":"property 1 value","type":"string"},"param2":{"description":"property 2 value","type":"string"}},"required":["param1","param2"]}') IF NOT EXISTS;
INSERT INTO sunbird_notifications.notification_template(templateId, type, ver, data, template_schema) VALUES ('context-deleted','JSON','4.3.0','{"title": "${param1} has been deleted by ${param2}"}', '{"$schema":"#/definition/params","title":"params context","description":"properties Data","type":"object","properties":{"param1":{"description":"property 1 value","type":"string"},"param2":{"description":"property 2 value","type":"string"}},"required":["param1","param2"]}') IF NOT EXISTS;
INSERT INTO sunbird_notifications.notification_template(templateId, type, ver, data, template_schema) VALUES ('context-assigned','JSON','4.3.0','{"title": "${param1} has been assigned to ${param2} by ${param3}"}', '{"$schema":"#/definition/params","title":"params context","description":"properties Data","type":"object","properties":{"param1":{"description":"property 1 value","type":"string"},"param2":{"description":"property 2 value","type":"string"},"param3":{"description":"property 3 value","type":"string"}},"required":["param1","param2","param3"] }') IF NOT EXISTS;
INSERT INTO sunbird_notifications.notification_template(templateId, type, ver, data, template_schema) VALUES ('context-unassigned','JSON','4.3.0','{"title": "${param1} has been unassigned to ${param2} by ${param3}"}', '{"$schema":"#/definition/params","title":"params context","description":"properties Data","type":"object","properties":{"param1":{"description":"property 1 value","type":"string"},"param2":{"description":"property 2 value","type":"string"},"param3":{"description":"property 3 value","type":"string"}},"required":["param1","param2","param3"] }') IF NOT EXISTS;
INSERT INTO sunbird_notifications.notification_template(templateId, type, ver, data, template_schema) VALUES ('certificate-userfeed','JSON','4.3.0','{"title": "${param1}", "description": "${param2}"}', '{"$schema":"#/definition/params","title":"${param1}","description":"${param2}","type":"object","properties":{"param1":{"description":"courseName","type":"string"},"param2":{"description":"user feed message","type":"string"}},"required":["param1","param2"] }') IF NOT EXISTS;


-- Table: action_template
